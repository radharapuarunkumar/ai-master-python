# ===========================================================================
# .gitignore — AI Master Python
# ===========================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
*.whl
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ---------------------------------------------------------------------------
# Type checking & Linting
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
# Keep the example file
!.env.example

# Custom Secrets
secrets/
firebase-admin.json

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# Ignore local docker volume data if mounted outside named volumes
docker/volumes/

# ---------------------------------------------------------------------------
# IDE & Editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
*.bak
*.tmp
.scratch/

{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/app/main.py" },
    { "source": "/docs", "destination": "/app/main.py" },
    { "source": "/openapi.json", "destination": "/app/main.py" },
    { "source": "/health", "destination": "/app/main.py" },
    { "source": "/health/(.*)", "destination": "/app/main.py" },
    { "source": "/", "destination": "/frontend/pages/login.html" }
  ]
}

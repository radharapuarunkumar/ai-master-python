# ===========================================================================
# AI Master Python — Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# NEVER commit the .env file to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# APP
# ---------------------------------------------------------------------------
APP_NAME="AI Master Python"
DEBUG=false
# Prefix applied to all v1 API routes (e.g. /api/v1/courses)
API_V1_PREFIX="/api/v1"
# The URL of the frontend SPA — used for CORS and OAuth redirect URIs
FRONTEND_URL="http://localhost:3000"
# Comma-separated list of allowed CORS origins (leave empty to use FRONTEND_URL only)
CORS_ORIGINS=""

# ---------------------------------------------------------------------------
# DATABASE  (PostgreSQL + pgvector)
# ---------------------------------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://aimaster:changeme@db:5432/aimaster"
# Connection pool tuning
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------------------
# Format: redis://[:password]@host:port/db
REDIS_URL="redis://redis:6379/0"

# ---------------------------------------------------------------------------
# AUTH  (Google OAuth 2.0 + JWT)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# JWT settings
JWT_SECRET_KEY="CHANGE-ME-to-a-random-64-char-hex-string"
JWT_ALGORITHM="HS256"
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# AI  (Google Gemini)
# ---------------------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key"
# Model used for text generation (tutoring, explanations, quiz generation)
GEMINI_TEXT_MODEL="gemini-2.5-flash"
# Model used for multimodal / vision tasks
GEMINI_VISION_MODEL="gemini-2.5-flash"
# Model used for embedding generation (semantic search, RAG)
GEMINI_EMBEDDING_MODEL="text-embedding-004"

# ---------------------------------------------------------------------------
# LIVEKIT  (real-time voice / video sessions)
# ---------------------------------------------------------------------------
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# ---------------------------------------------------------------------------
# STORAGE  (S3-compatible object storage — AWS S3 / MinIO / R2)
# ---------------------------------------------------------------------------
STORAGE_BACKEND="s3"
S3_BUCKET_NAME="ai-master-assets"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
# For MinIO or other S3-compatible services, set the endpoint URL:
S3_ENDPOINT_URL=""

# ---------------------------------------------------------------------------
# EMAIL  (SMTP)
# ---------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="noreply@aimaster.dev"
SMTP_FROM_NAME="AI Master Python"
SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# CELERY  (async task queue — uses REDIS_URL by default)
# ---------------------------------------------------------------------------
CELERY_BROKER_URL="redis://redis:6379/1"
CELERY_RESULT_BACKEND="redis://redis:6379/2"
